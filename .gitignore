# secrets — never commit real API keys
.env

# data & models (large files, shouldn't go in git)
data/*
!data/.gitkeep
models/
*.gguf

# run outputs
runs/

# transient scratch file the Interpreter's child process writes generated
# code to at runtime (src/interpreter/interpreter.py's agent_file_name) --
# a stray copy at the repo root was accidentally committed once; this
# stops that from happening again.
runfile.py

# python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# os / editor
.DS_Store
.vscode/
.idea/
