# Copy this file to `.env` and fill in your real values.
# `.env` itself is gitignored and will never be committed — only this
# example template (with no real secrets) is tracked in git.

# Required when configs/config.yaml has llm.backend: "openai"
OPENAI_API_KEY=sk-your-key-here

# Only needed if you add/use an Anthropic backend later
# ANTHROPIC_API_KEY=sk-ant-your-key-here
