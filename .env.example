# Copy this file to `.env` and fill in your real values.
# `.env` itself is gitignored and will never be committed — only this
# example template (with no real secrets) is tracked in git.

# Required when configs/config.yaml has llm.backend: "openai"
OPENAI_API_KEY=sk-your-key-here

# Required when llm.backend is "anthropic" instead (get this from
# platform.claude.com -> Settings -> API Keys; this is separate from any
# claude.ai chat subscription)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required when llm.backend is "coze" instead. COZE_API_TOKEN is a
# personal access token from https://www.coze.cn/open/oauth/pats.
# COZE_BOT_ID is the ID of a bot YOU create and publish as an API service
# in the Coze web UI first (find it in that bot's URL) -- there is no
# COZE_BOT_ID until you've done that, this isn't something you can just
# fill in from a settings page like the two keys above.
COZE_API_TOKEN=your-coze-personal-access-token-here
COZE_BOT_ID=your-published-bot-id-here
